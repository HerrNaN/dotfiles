{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "permission": {
    "bash": {
      "git *": "ask",
      "git status *": "allow",
      "git branch -a": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git grep *": "allow",
      "git commit *": "allow",
      "git show *": "allow",
      "git ls-remote *": "allow",
      "az *": "deny",
      "az boards work-item show *": "allow",
      "az account get-access-token *": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
    }
  }
}
